generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id              String   @id @default(uuid())
  ledger          Int
  txHash          String
  contractId      String
  topic           String
  data            String   // XDR encoded or parsed JSON
  createdAt       DateTime @default(now())

  @@unique([txHash, topic, data]) // Idempotency
}

model IndexerState {
  id              String   @id @default("singleton")
  lastLedger      Int
}

model VaultBalance {
  id              String   @id @default(uuid())
  walletAddress   String   @unique
  tvl             Float    @default(0)
  totalYield      Float    @default(0)
  updatedAt       DateTime @updatedAt
}

model Notification {
  id              String   @id @default(uuid())
  walletAddress   String
  type            String   // DEPOSIT, WITHDRAWAL, ANNOUNCEMENT, HARVEST
  title           String
  message         String
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model OnRampTransaction {
  id              String   @id @default(uuid())
  walletAddress   String
  provider        String   // STRIPE, MOONPAY
  status          String   // PENDING, COMPLETED, FAILED
  amountFiat      Float
  currency        String
  amountUsdc      Float    @default(0)
  providerTxId    String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── PnL Engine Models (Issue #107) ──────────────────────────────────────

model SharePriceSnapshot {
  id              String   @id @default(uuid())
  vaultId         String
  sharePrice      Float    // price per share in USDC (or base asset)
  totalShares     Float
  totalAssets     Float
  snapshotAt      DateTime @default(now())

  @@index([vaultId, snapshotAt])
}

model UserTransaction {
  id              String   @id @default(uuid())
  walletAddress   String
  vaultId         String
  action          String   // DEPOSIT, WITHDRAW, HARVEST
  amount          Float    // amount in base asset (USDC)
  shares          Float    // shares minted or burned
  sharePriceAtTx  Float    // share price at time of transaction
  txHash          String   @unique
  timestamp       DateTime
  createdAt       DateTime @default(now())

  @@index([walletAddress, vaultId])
  @@index([walletAddress, timestamp])
}

// ── CSV Export Models (Issue #113) ──────────────────────────────────────

model ExportJob {
  id              String   @id @default(uuid())
  walletAddress   String
  status          String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  fileUrl         String?
  error           String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  @@index([walletAddress, createdAt])
}

// ── Referral System Models (Issue #115) ─────────────────────────────────

model Referral {
  id              String   @id @default(uuid())
  referrerAddress String
  refereeAddress  String   @unique
  referredTvl     Float    @default(0)
  totalRewards    Float    @default(0)
  createdAt       DateTime @default(now())

  @@index([referrerAddress])
}

// ── APY Alert Models ─────────────────────────────────────────────────────────

model UserAlert {
  id              String   @id @default(uuid())
  walletAddress   String
  vaultId         String   // protocol name / vault identifier
  condition       String   // "above" | "below"
  thresholdValue  Float    // APY percentage threshold (e.g. 10.0 for 10%)
  email           String   // destination email for notifications
  status          String   @default("active") // "active" | "triggered" | "deleted"
  triggeredAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([walletAddress])
  @@index([status, vaultId])
}

// ── Encrypted Address Book Models (Issue #140) ───────────────────────────────

model Contact {
  id                String   @id @default(uuid())
  walletAddress     String   // Owner's wallet address
  encryptedName     String   // Base64 encrypted contact name
  encryptedAddress  String   // Base64 encrypted contact address
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([walletAddress, createdAt])
  @@unique([walletAddress, encryptedAddress]) // Prevent duplicates per user
}

// ── Risk Incident Models (#286) ───────────────────────────────────────────

model Incident {
  id              String   @id @default(uuid())
  protocol        String   // protocol name (Blend, Soroswap, etc.)
  severity        String   // LOW, MEDIUM, HIGH, CRITICAL
  type            String   // PAUSE, ANOMALY, DEPEG, EXPLOIT, INTERVENTION
  title           String
  description     String
  affectedVaults  String[] // Array of vault IDs/names
  resolved        Boolean  @default(false)
  startedAt       DateTime
  resolvedAt      DateTime?
  postmortemUrl   String?  // Link to postmortem document
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([protocol, severity])
  @@index([startedAt])
}

// ── Drift Detection Models ──────────────────────────────────────────────────

model DriftEvent {
  id              String   @id @default(uuid())
  vaultId         String
  targetWeight    Float
  actualWeight    Float
  driftAmount     Float    // actualWeight - targetWeight
  isRecovered     Boolean  @default(false)
  createdAt       DateTime @default(now())
  resolvedAt      DateTime?

  @@index([vaultId, isRecovered])
}

// ── Rebalance Queue Models (Issue #281) ─────────────────────────────────────────

model RebalanceQueueEntry {
  id                  String   @id @default(uuid())
  vaultId             String
  status              String   @default("PENDING") // PENDING, PROCESSING, PARTIAL, COMPLETED, FAILED, CANCELLED
  executionType       String   // FULL, PARTIAL, DEFERRED
  
  // Rebalance request details
  targetAllocations   Json     // JSON object with target weights
  currentAllocations  Json     // JSON object with current weights
  executionStrategy   Json     // JSON execution plan
  partiallyExecuted   Boolean  @default(false)
  partialFillAmount   Float    @default(0)
  
  // Intent tracking for security
  intentHash          String   // Hash of the intent for replay prevention
  intentValidUntil    DateTime // Expiry time for the intent
  
  // Retry tracking
  attemptCount        Int      @default(0)
  maxRetries          Int      @default(3)
  nextRetryAt         DateTime?
  lastError           String?
  
  // Execution tracking
  lastTransactionHash String?
  lastLedger          Int?
  lastErrorClass      String?
  executionMetadata   Json?
  
  // Deferred execution details
  deferredReason      String?  // Reason for deferral
  deferredUntil       DateTime?
  followUpEntryId      String?  // Link to follow-up queue entry
  
  // Audit fields
  triggeredBy         String?  // System or user who triggered
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([vaultId, status])
  @@index([status, nextRetryAt])
  @@index([createdAt])
  @@unique([intentHash, vaultId]) // Prevent duplicate intents for same vault
}

model RebalanceHistory {
  id                  String   @id @default(uuid())
  queueEntryId        String   @unique
  vaultId             String
  executionType       String   // FULL, PARTIAL, DEFERRED
  executionResult     Json     // Details about what was executed
  totalExecuted       Float    // Total amount executed
  expectedAmount      Float    // Expected amount before partial fill
  filledPercentage    Float    // Percentage of expected amount
  transactionHash     String?  // Blockchain tx hash if applicable
  ledger              Int?     // Ledger sequence when transaction was included
  errorClass          String?  // transient | terminal | simulation
  completedAt         DateTime
  createdAt           DateTime @default(now())

  @@index([vaultId, completedAt])
  @@index([completedAt])
}

// ── Strategy Snapshot Models (Issue #282) ────────────────────────────────────

model StrategySnapshot {
  id                  String   @id @default(uuid())
  strategyId          String
  version             Int      // Version number (incremental)
  
  // Configuration snapshot
  name                String
  description         String?
  keyWeights          Json     // Immutable snapshot of key weights at this version
  riskParameters      Json     // Immutable snapshot of risk parameters
  constraints         Json     // Immutable allocation constraints
  
  // Metadata
  status              String   @default("ACTIVE") // ACTIVE, SUPERSEDED, ARCHIVED
  createdAt           DateTime @default(now())
  supersededAt        DateTime? // When this version was replaced
  supersededByVersion Int?     // Reference to newer version
  
  // Audit
  changeReason        String?  // Why this version was created
  changeAuthor        String?  // Who made the change
  
  @@unique([strategyId, version]) // One version per strategy
  @@index([strategyId, status])
  @@index([strategyId, createdAt])
}

model StrategyVersionReference {
  id                  String   @id @default(uuid())
  strategySnapshotId  String   // References StrategySnapshot.id
  strategyId          String
  snapshotVersion     Int      // Copy of version for quick access
  
  // Records tied to this version
  recommendationId    String?  // Recommendation that used this version
  rebalanceQueueId    String?  // Rebalance event that used this version
  eventType           String   // RECOMMENDATION, REBALANCE, SNAPSHOT
  
  // Audit context
  linkedAt            DateTime @default(now())
  linkedBy            String?  // Who/what linked this version

  @@index([strategyId, recommendationId])
  @@index([strategyId, rebalanceQueueId])
  @@index([strategySnapshotId, eventType])
}

model StrategyVersionHistory {
  id                  String   @id @default(uuid())
  strategyId          String
  versionChanges      Json     // What changed between versions
  fromVersion         Int
  toVersion           Int
  changeType          String   // WEIGHTS_UPDATE, CONSTRAINTS_UPDATE, PARAMETERS_UPDATE, FULL_REVISION
  reason              String
  author              String?
  createdAt           DateTime @default(now())

  @@index([strategyId, createdAt])
  @@index([strategyId, fromVersion, toVersion])
}

// ── Portfolio Regime Shift Models (Issue #376) ──────────────────────────────

model PortfolioRegimeShiftAlert {
  id              String   @id @default(uuid())
  walletAddress   String
  previousRegime  String   // stable | high-volatility | declining-yield | incentive-spike
  currentRegime   String
  confidence      Float
  rationale       String
  notified        Boolean  @default(false)
  notifiedAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([walletAddress, createdAt])
  @@index([walletAddress, currentRegime, createdAt])
}

// ── Unified Governance Control Plane Models (Issue #81) ─────────────────────

// Canonical record of a privileged action proposal. Every admin mutation
// covered by the governance control plane creates or references one of
// these rather than reporting an unexecuted action as completed. Status is
// ultimately reconciled from on-chain events/tx results, not just server
// intent - see GovernanceEvent below.
model GovernanceProposal {
  id                  String   @id @default(uuid())

  // Canonical action payload (see server/src/governance/actionSchema.ts).
  // actionHash is the sha256 shared by client preview, server record,
  // signatures, on-chain proposal, and execution event.
  actionHash          String   @unique
  schemaVersion       Int
  network             String
  targetContractId    String
  method              String
  argsJson            Json
  expectedStateJson   Json
  proposer            String
  creationLedger      Int
  executionWindowSecs Int
  rationale           String

  // Links (Issue #81 requirement: link every proposal to strategy version,
  // risk forecast, audit record, and resulting state transition).
  strategyVersionId   String?
  riskForecastId      String?
  auditLogId          String?

  // On-chain identity, once proposed on the optimistic_governance contract.
  onChainProposalId   BigInt?
  governanceContractId String?

  status              String   @default("PENDING")
  // PENDING, CHALLENGED, APPROVED, EXECUTABLE, SUBMITTED, CONFIRMED,
  // FAILED, CANCELLED, EXPIRED

  executionTxHash     String?
  executionLedger     Int?
  failureReason       String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  simulations         GovernanceSimulation[]
  events              GovernanceEvent[]

  @@index([status])
  @@index([proposer, createdAt])
  @@index([method, createdAt])
}

// Simulation evidence recorded before a proposal may be approved for
// execution. A stale simulation (state or ledger age beyond the configured
// bound) must not be presented as current without a warning + execution
// gate - see isSimulationStale in governanceProposalService.ts.
model GovernanceSimulation {
  id                  String   @id @default(uuid())
  proposalId          String
  proposal            GovernanceProposal @relation(fields: [proposalId], references: [id])

  simulatedAtLedger   Int
  simulationExpiry    DateTime

  footprintJson       Json     // transaction footprint (read/write keys)
  resultJson          Json     // simulated result payload
  diagnosticEventsJson Json    // diagnostic events emitted during simulation
  expectedStateDiffJson Json   // computed before/after state diff
  resourceFee         String   // stroops, stored as string to avoid float precision loss
  riskWarnings        String[] @default([])

  createdAt           DateTime @default(now())

  @@index([proposalId, createdAt])
}

// Indexed on-chain events for governance proposals (propose/dispute/resolve/
// cancel/execute). Proposal status must be reconstructable from these events
// and transaction results alone, so the application DB can be rebuilt from
// an empty state by replaying them.
model GovernanceEvent {
  id                  String   @id @default(uuid())
  proposalId          String?
  proposal            GovernanceProposal? @relation(fields: [proposalId], references: [id])

  onChainProposalId   BigInt
  eventType           String   // PROPOSE, DISPUTE, RESOLVE, CANCEL, EXECUTE
  ledger              Int
  txHash              String
  topic               String
  dataJson            Json

  createdAt           DateTime @default(now())

  @@unique([txHash, topic, onChainProposalId])
  @@index([onChainProposalId, ledger])
}

// ── Allocation Provenance Models ──────────────────────────────────────────────

model AllocationProvenance {
  decisionId          String   @id
  vaultId             String
  strategyVersion     String
  timestamp           DateTime
  triggerCondition    String
  triggerInputs       Json
  previousAllocation  Json
  updatedAllocation   Json
  signer              String

  @@index([vaultId])
  @@index([timestamp])
}

// ── Rebalance Auction Models (MEV-Resistant Solver Auction) ────────────────

model RebalanceAuctionIntent {
  id                      String   @id @default(uuid())
  intentId                BigInt   @unique // On-chain intent ID
  vaultId                 String
  vaultContractId         String
  
  // Strategy snapshot reference
  strategySnapshotId      String
  strategyVersion         Int
  
  // Execution state machine
  state                   String   @default("INTENT_CREATED") // INTENT_CREATED, AUCTION_OPEN, BIDDING_CLOSED, WINNER_SELECTED, SETTLEMENT_PENDING, SETTLED, FAILED, CANCELLED, EXPIRED
  
  // Intent constraints
  inputPositions          Json     // Array of InputPosition
  targetConstraints       Json     // Array of AllocationConstraint
  maxTotalLossBps         Int
  maxSlippageBps          Int
  maxFeesBps              Int
  maxPriceImpactBps       Int
  minTotalOutputValue     BigInt
  totalInputValue         BigInt
  totalOutputValue        BigInt   @default(0)
  
  // Allowlists
  allowedTokens           Json     // Array of token addresses
  allowedProtocols        Json     // Array of protocol addresses
  
  // Partial fill policy
  partialFillPolicy       String   @default("FULL_ONLY") // FULL_ONLY, PRO_RATA, MIN_PERCENT
  
  // Intent identity
  nonce                   BigInt
  intentHash              String   @unique
  creationLedger          BigInt
  expiryLedger            BigInt
  cancellationAuthority   String
  
  // Timing
  commitPhaseEnd          DateTime?
  revealPhaseEnd          DateTime?
  
  // Settlement
  winningSolver           String?
  settlementTxHash        String?
  settlementLedger        BigInt?
  realizedSlippageBps     Int?
  filledPercentage        Int      @default(10000) // bps
  
  // Audit
  triggeredBy             String?
  completedAt             DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([vaultId, state])
  @@index([state, expiryLedger])
  @@index([intentHash])
  @@index([createdAt])
  bids                    SolverBid[]
  settlement              AuctionSettlement?
}

model SolverBid {
  id                      String   @id @default(uuid())
  intentId                String   // References RebalanceAuctionIntent.id
  solverAddress           String
  
  // Commit phase
  commitHash              String
  commitTimestamp         DateTime
  
  // Reveal phase
  revealed                Boolean  @default(false)
  outputAmounts           Json     // Map of token → amount
  totalOutputValue        BigInt
  route                   Json     // Array of RouteLeg
  feesBps                 Int
  slippageBps             Int
  priceImpactBps          Int
  bidHash                 String?
  revealTimestamp         DateTime?
  
  // Bond
  bondAmount              BigInt   @default(0)
  bondSlashed             Boolean  @default(false)
  
  // Ranking
  rank                    Int?     // Final ranking (1 = winner)
  
  // Timing
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  intent                  RebalanceAuctionIntent @relation(fields: [intentId], references: [id])
  
  @@unique([intentId, solverAddress])
  @@index([solverAddress])
  @@index([intentId, revealed])
}

model AuctionSettlement {
  id                      String   @id @default(uuid())
  intentId                String   @unique // References RebalanceAuctionIntent.id
  solverAddress           String
  
  // Execution details
  txHash                  String
  settlementLedger        BigInt
  settledAt               DateTime
  
  // Balance reconciliation
  preBalances             Json     // Map of token → balance before
  postBalances            Json     // Map of token → balance after
  fillDeltas              Json     // Map of token → actual delta
  
  // Fees and slippage
  totalFees               BigInt
  realizedSlippageBps     Int
  protocolFeeBps          Int
  
  // Partial fill tracking
  partialFill             Boolean  @default(false)
  filledPercentage        Int      @default(10000) // bps
  
  // Audit
  createdAt               DateTime @default(now())

  intent                  RebalanceAuctionIntent @relation(fields: [intentId], references: [id])
  
  @@index([solverAddress])
  @@index([txHash])
}

model SolverBond {
  id                      String   @id @default(uuid())
  solverAddress           String
  intentId                String
  bondAmount              BigInt
  status                  String   @default("LOCKED") // LOCKED, RELEASED, SLASHED
  depositedAt             DateTime @default(now())
  releasedAt              DateTime?
  
  @@unique([solverAddress, intentId])
  @@index([solverAddress, status])
  @@index([intentId])
}

model ExecutionAuditLog {
  id                      String   @id @default(uuid())
  intentId                String
  eventType               String   // INTENT_CREATED, BID_COMMITTED, BID_REVEALED, WINNER_SELECTED, SETTLEMENT_SUBMITTED, SETTLEMENT_CONFIRMED, CANCELLED, EXPIRED, BOND_SLASHED, BOND_RELEASED
  actor                   String   // Address that triggered the event
  details                 Json     // Event-specific details
  ledgerSequence          BigInt?
  txHash                  String?
  createdAt               DateTime @default(now())

  @@index([intentId, eventType])
  @@index([createdAt])
  @@index([actor])
}

model SolverReputation {
  id                      String   @id @default(uuid())
  solverAddress           String   @unique
  score                   Int      @default(0)
  totalSettled            Int      @default(0)
  successfulSettles       Int      @default(0)
  failedSettles           Int      @default(0)
  bondsSlashed            Int      @default(0)
  lastSettledAt           DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([score])
  @@index([solverAddress])
}
