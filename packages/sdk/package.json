{
  "name": "@stellaryield/sdk",
  "version": "0.1.0",
  "description": "StellarYield Developer SDK for building on top of StellarYield vaults",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:bindings": "npx tsx scripts/build-bindings.ts",
    "verify:drift": "npx tsx scripts/verify-drift.ts",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "stellar",
    "soroban",
    "yield",
    "vault",
    "defi",
    "sdk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/edehvictor/StellarYield.git",
    "directory": "packages/sdk"
  }
}
